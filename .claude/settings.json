{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(git checkout:*)",
      "Bash(git show-ref:*)",

      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",

      "Bash(dev/setup-worktree.sh:*)",
      "Bash(dev/teardown-worktree.sh:*)",
      "Bash(dev/run-tests.sh:*)",
      "Bash(dev/ha-env.sh:*)",
      "Bash(dev/mock_ubus_server.py:*)",
      "Bash(dev/setup-ha.py:*)",

      "Bash(PYTHONPATH=. .venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m black:*)",
      "Bash(.venv/bin/python -m isort:*)",
      "Bash(.venv/bin/python -m flake8:*)",
      "Bash(.venv/bin/python dev/:*)",
      "Bash(.venv/bin/python -c:*)",

      "Bash(podman logs:*)",
      "Bash(podman ps:*)",

      "Bash(curl -s:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(mkdir -p:*)",

      "WebFetch(domain:github.com)",
      "WebFetch(domain:developers.home-assistant.io)"
    ],
    "deny": []
  }
}
